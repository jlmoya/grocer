function y=squarets(x)
 
// PURPOSE: provides the square of a ts (needed to
// provide automatically the inverse of function sqrt
// ------------------------------------------------------------
// INPUT:
// * x = a ts
// ------------------------------------------------------------
// OUTPUT:
// * y = a ts
// ------------------------------------------------------------
// Copyright: Eric Dubois 2009
// http://grocer.toolbox.free.fr/grocer.html
 
y=x^2
 
endfunction
