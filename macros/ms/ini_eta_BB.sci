function PZini=ini_eta_BB(eta);
 
//*****************************************************************************//
//** 6. INI_ETA                                                              **//
//*****************************************************************************//
 
M=size(eta,1)
A = [(eye(M,M)-eta) ; ones(1,M)]
EN=[zeros(M,1);1]
PZini = pinv(A'*A)*A'*EN
 
endfunction
 
