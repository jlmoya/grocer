function s=%ts_mini(ts)
 
// PURPOSE: returns the minimum of a ts
// ------------------------------------------------------------
// INPUT:
// * ts = a time series
// ------------------------------------------------------------
// OUTPUT:
// * s = a real number: the minimum of the series
// ------------------------------------------------------------
// Copyright: Eric Dubois 2007
// http://grocer.toolbox.free.fr/grocer.html
 
s=min(ts('series'))
 
endfunction
