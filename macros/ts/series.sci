function [s]=series(ts)
 
// PURPOSE: return the vector of a time series values
// ------------------------------------------------------------
// INPUT:
// ts = a time series
// ------------------------------------------------------------
// OUTPUT:
// s = the vector of the time series values
// ------------------------------------------------------------
// NOTES:
// ------------------------------------------------------------
// Copyright: Eric Dubois 2002
// http://grocer.toolbox.free.fr/grocer.html
 
s=ts('series')
 
endfunction
