function [d]=datets(ts)
 
// PURPOSE: retrieve the dates of a time series
// ------------------------------------------------------------
// INPUT:
// ts = a time series
// ------------------------------------------------------------
// OUTPUT:
// d = the numerical representation of ts dates
// ------------------------------------------------------------
// NOTES:
// ------------------------------------------------------------
// Copyright: Eric Dubois 2002
// http://grocer.toolbox.free.fr/grocer.html
 
d=ts('dates')
 
endfunction
