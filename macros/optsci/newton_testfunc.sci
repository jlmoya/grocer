function f=newton_testfunc(x)

f=zeros(5,1)
f(1)=4*(x(1)-x(2)^2)+x(2)-x(3)^2
f(2)=x(2)*(x(2)^2-x(1))-2*(1-x(2))+4*(x(2)-x(3)^2)+x(3)-x(4)^2
f(3)=x(3)*(x(3)^2-x(2))-2*(1-x(3))+4*(x(3)-x(4)^2)+x(2)^2-x(1)+x(4)-x(5)^2
f(4)=x(4)*(x(4)^2-x(3))-2*(1-x(4))+4*(x(4)-x(5)^2)+x(3)^2-x(2)
f(5)=x(5)*(x(5)^2-x(4))-2*(1-x(5))+x(4)^2-x(3)

endfunction
