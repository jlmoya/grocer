function J=newton_testJac(x)
    
J=zeros(5,5)
J(1,1)=4
J(1,2)=-8*x(2)+1
J(1,3)=-2*x(3)
J(2,1)=-x(2)
J(2,2)=3*x(2)^2-x(1)+6
J(2,3)=-8*x(3)+1
J(2,4)=-2*x(4)
J(3,1)=-1
J(3,2)=-x(3)+2*x(2)
J(3,3)=3*x(3)^2-x(2)+6
J(3,4)=-8*x(4)+1
J(3,5)=-2*x(5)
J(4,2)=-1
J(4,3)=-x(4)+2*x(3)
J(4,4)=3*x(4)^2-x(3)+6
J(4,5)=-8*x(5)
J(5,3)=-1
J(5,4)=-x(5)+2*x(4)
J(5,5)=3*x(5)^2-x(4)+2

endfunction
