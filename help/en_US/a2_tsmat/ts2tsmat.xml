   <refnamediv>
       <refname>ts2tsmat</refname>
               <refpurpose>Converts time series into a tsmat </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>tsm=ts2tsmat(arg1,...,argn)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> argi </term> =    time series, the string 'cte' or 'const' vectors or matrices that have the same # of rows, itself equal to the # of time periods matched by the ts</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> tsm </term> =    a tlist of type tsmat</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Converts n time series into a tsmat
 
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 ts1=reshape([1:10],'1a');
 ts2=reshape(2*[1:10],'1a');
 tsmat1=ts2tsmat('ts1','ts2');
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2008
        </refsection>
</refentry>
