   <refnamediv>
       <refname>invxpx </refname>
               <refpurpose>inversion of X'X </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[xpxi]=invxpx(x)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> x </term> =    a (n x k) real matrix</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> xpxi </term> =    the (k x k) matrix equal to inv(x'x)</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Provides inversion of the matrix (X'X) using the QR decomposition.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
x=grand(30,3,'nor',0,1)
y=x*[0.2;0.4;0.35]+grand(30,1,'nor',0,1)
m = invxpx(x)
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
