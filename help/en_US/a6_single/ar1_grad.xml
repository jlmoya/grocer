   <refnamediv>
       <refname>ar1_grad </refname>
               <refpurpose>gradient for ols model with AR1 errors </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[grad]=ar1_grad(param,y,x)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> param </term> =   parameter vector (k x 1)</para></listitem>
<listitem><para>*  <term> y </term> =   dependent variable vector (n x 1)</para></listitem>
<listitem><para>*  <term> x </term> =   explanatory variables matrix (n x m)</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> grad </term> =   the gradient</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
 Evaluates minus the gradient of the log-likelihood for ols model with AR1 errors. Param(1,1) contains rho parameter.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
g=ar1_grad(parm,grocer_y,grocer_x)
// taken from olsar1.
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
