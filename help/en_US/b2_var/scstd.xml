   <refnamediv>
       <refname>scstd</refname>
               <refpurpose>determines bvar function scaling factor </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[scale]=scstd(y,nobs,nlag)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> y </term> =    an (nobs x neqs) matrix of y-vectors in levels</para></listitem>
<listitem><para>*  <term> nobs </term> =    # of observations in y</para></listitem>
<listitem><para>*  <term> nlag </term> =    the lag length</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> scale </term> =    std deviation of the residuals</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Determines bvar() function scaling factor using a univariate AR model (called by bvar1() only).
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
scale(j,1) = scstd(ytmp,nobs,nlag);
 
// Example taken from function bvar1 (!)
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
