   <refnamediv>
       <refname>num2date </refname>
               <refpurpose>transforms a number into a date </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>dat=num2date(num,f)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> num </term> =     a date in numerical presentation</para></listitem>
<listitem><para>*  <term> f </term> =     dates frequency (in constant format)</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> dat </term> =     a date in string format</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Transforms a date in numerical representation into its string one.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
num2date(200,1) // returns "200a"
num2date(200,4) // returns "49q4"
num2date(200,52) // returns "3/11/03"
num2date(200,26) // returns "7f26d18"
 
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
