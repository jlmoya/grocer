   <refnamediv>
       <refname>values </refname>
               <refpurpose>value of a ts at some date </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>val=values(ts,dat)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> ts </term> =     a timeseries</para></listitem>
<listitem><para>*  <term> dat </term> =     a date string</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> val </term> =     the value of a timeseries for the given date</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Returns the value of a timeseries for a given date
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
load(GROCERDIR+'/data/bdhenderic.dat') // load Hendry and Ericsson database
y=values(lm1,'1985q4')
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
