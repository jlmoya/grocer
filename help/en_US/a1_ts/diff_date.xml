   <refnamediv>
       <refname>diff_date </refname>
               <refpurpose>returns the difference between 2 dates </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>num=diff_date(lastdate,firstdate)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> lastdate </term> =     last date </para></listitem>
<listitem><para>*  <term> firstdate </term> =     first date</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> num </term> =     the number of observations between the 2 dates</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Computes the number of observations between 2 dates.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
d = diff_date('1995a','1985a')
// gives 10
d = diff_date('1987q4','1985q2')
// gives 10 too
d = diff_date('72m1','83m12')
// gives  -143
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
