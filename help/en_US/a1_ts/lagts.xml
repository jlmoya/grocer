   </info>
   <refnamediv>
       <refname>lagts </refname>
               <refpurpose>lag a ts </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>ts=lagts(arg1[,arg2])</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> arg1 </term> =     the order of differenciation (optional, set to 1 if not provided) or a ts</para></listitem>
<listitem><para>*  <term> arg2 (if arg1 was he order of differenciation) </term> =     a time series</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> ts </term> =     the lagged time series</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Computes x(t-n) for a timeseries x(t).
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
y=reshape(1:20,'1985m1') // create a ts
y = lagts(x) // y is x lagged once.
y = lagts(4,x) // y is x lagged four times
y = lagts(-1,x) // y is x forwarded once
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
