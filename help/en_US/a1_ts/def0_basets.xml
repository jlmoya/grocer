   <refnamediv>
       <refname>def0_basets </refname>
               <refpurpose>creation of the default frequencies data base </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>def0_basets()</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>* nothing</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing: data are saved into the file SCI\macros\grocer\db\basets.dat</para></listitem>
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Creates the default data base of the frequencies and their literal representation. Useful if the user has mishandeled the creation of her own database trough function def_basets and wants to recover the default data base.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
def0_basets()
// This is the only use for this function.
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2005
        </refsection>
</refentry>
