   <refnamediv>
       <refname>datets </refname>
               <refpurpose>returns the time span of a ts </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>d=datets(ts)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
<listitem><para>*  <term> ts </term> =     a time series</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> d </term> =     the numerical representation of ts dates</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Returns the time span of a ts.
 
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
