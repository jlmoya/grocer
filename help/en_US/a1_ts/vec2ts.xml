   <refnamediv>
       <refname>vec2ts </refname>
               <refpurpose>vector to timeseries </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[tsout]=vec2ts(vector,boun)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> vector </term> =     a (1xn) or (nx1) vector</para></listitem>
<listitem><para>*  <term> boun </term> =     a (1xn) or (nx1) string vector of bounds</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> tsout </term> =     the corresponding timeseries</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Transforms into a timeseries a vector according to given bounds.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
t=vec2ts([1:24 28:32],['1a' ; '24a' ; '28a' ; '32a'])
// Creates a ts which is a time trend from 1a to 32a, with three nan values between 25a and 27a.
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2003
        </refsection>
</refentry>
