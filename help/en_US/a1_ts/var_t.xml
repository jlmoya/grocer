   <refnamediv>
       <refname>var_t </refname>
               <refpurpose>variances of n ts at a given date </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[ts]=var_t(ts1,...,tsn) </synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> tsi </term> =     a time series</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> ts </term> =     the time series whose values are, for each date the variance at this date of the values of the n time series</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Computes the timeseries whose values are, for each date, the variance at this date of the values of n time series. Doubtful usefulness, but exists!
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
load(GROCERDIR+'/data/bdhenderic.dat') // load Hendry and Ericsson database
y = var_t(delts(lm1),delts(lp),delts(ly))
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
