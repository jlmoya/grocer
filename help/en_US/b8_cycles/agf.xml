   <refnamediv>
       <refname>agf </refname>
               <refpurpose>autocovariance generating function </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>ac = agf(w,AR,MA)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> w  </term> =    point where to evaluate</para></listitem>
<listitem><para>*  <term> AR  </term> =    matrix of AR coefficients AR  =    [A1 .. Ap]</para></listitem>
<listitem><para>*  <term> MA  </term> =    matrix of MA coefficients MA  =    [B1 .. Bq]</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term>  ac </term> =    AGF for VARMA</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Evaluates autocovariance generating function for AR and MA at point w.
 
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
ac= agf(w,[0.1 0.2],[0.43 0.21])
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Emmanuel Michaux 2005
        </refsection>
</refentry>
