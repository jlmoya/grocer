   <refnamediv>
       <refname>explolist</refname>
               <refpurpose>splitting of a list </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[l1,l3]=explolist(l1,l2)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> l1 </term> =   the list to split</para></listitem>
<listitem><para>*  <term> l2 </term> =  the list of conditions</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> l1 </term> =   the initial list without the elements verifying the conditions</para></listitem>
<listitem><para>*  <term> l3 </term> =   the initial list with the elements verifying the conditions</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Splits the list l1 in 2 lists containing the elements that do (l3) or do not (l1) verify the conditions contained in list l2. Obsolete function.
        </refsection>
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
[grocer_lx,grocer_lnp]=explolist(grocer_lx,list('grocer_lx(i)==''noprint'''))
               ]]></programlisting>
        </refsection>
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
