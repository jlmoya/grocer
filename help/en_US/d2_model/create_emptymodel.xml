   <refnamediv>
       <refname>create_emptymodel</refname>
               <refpurpose>create an empty model </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>model=create_emptymodel(namemod)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>

<listitem><para>*  <term>namemod</term>&#160;=&#160;the&#160;name&#160;of&#160;the&#160;model</para></listitem>

           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
 
<listitem><para>*  <term>model</term> = a model tlist with all tlist fields defined, but only the name of the model filled</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Creates the tlist of an empty model, that is without any declaration or equation.
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
mymodel=create_emptymodel('mymodel')
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
&#201;ric Dubois 2018
        </refsection>
</refentry>
