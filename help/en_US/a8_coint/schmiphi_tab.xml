   <refnamediv>
       <refname>schmiphi_tab </refname>
               <refpurpose>critical values for the Schmidt-Phillips statistic </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[critical1,critical2]=schmiphi_tab(p,T)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>* <term>p</term>= order of the polynomial trend</para></listitem>
<listitem><para>* <term>T</term>= # of observations</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* <term>critical1</term>= (1% - 2.5% - 5% -10%) critical values of the rho test</para></listitem>
<listitem><para>* <term>critical2</term>= (1% - 2.5% - 5% -10%) critical values of the tau test</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Returns critical values for the Schmidt-Phillips statistic.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
[c1,c2]=schmiphi_tab(1,100)
 
// Provides Schmidt and Phillips table for a model with a simple trend and 100 observations.
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
