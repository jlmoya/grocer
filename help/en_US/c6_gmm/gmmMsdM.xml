   <refnamediv>
       <refname>gmmMsdM </refname>
               <refpurpose>Provide moment conditions for Mean/StdDev GMM estimation </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[m,e] = gmmMsdM(b,gmmopt,Y,X,Z)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> b </term> =    parameter vector fed to function</para></listitem>
<listitem><para>*  <term> gmmopt </term> =    gmm options tlist</para></listitem>
<listitem><para>*  <term> Y </term> =    "dependent" variables</para></listitem>
<listitem><para>*  <term> X </term> =    "independent" variables</para></listitem>
<listitem><para>*  <term> Z </term> =    instruments (can be same as X)</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term>  m </term> =    vector of moment conditions</para></listitem>
<listitem><para>*  <term>  e  </term> =    model errors  (Nobs x Neq)</para></listitem>
 
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Provides moment conditions and error term for Mean/Covar GMM estimation
<para> </para>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Emmanuel Michaux 2007
        </refsection>
</refentry>
