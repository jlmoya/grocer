   <refnamediv>
       <refname>gmmDiagW </refname>
               <refpurpose>Plots GMM weighting matrix </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>gmmDiagW(W,iter)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> W </term> =    matrix to print</para></listitem>
<listitem><para>*  <term> iter </term> =    indicates iteration number</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  nothing</para></listitem>
 
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Plots in a 3D histogramm the GMM weighting matrix at each iteration
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
gmmDiagW(W,i);
//Examples taken from gmm1
 
               ]]></programlisting>
        </refsection>
 
