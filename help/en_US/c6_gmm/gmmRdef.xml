   <refnamediv>
       <refname>gmmRdef </refname>
               <refpurpose>Computes the value for the restrictions in a nonlinear Wald test </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>fr = gmmRdef(parm,R)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> parm </term> =    value of the parameters</para></listitem>
<listitem><para>*  <term> R </term> =    (s x 1) string vector of restrictions</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* <term>fr</term> = a (s x 1) vector containing value of the constraints at parm value</para></listitem>
 
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Computes the value for the restrictions in a nonlinear Wald test
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 fr = gmmRdef(bet,R);
// Example taken from gmmNlWald :
 
               ]]></programlisting>
        </refsection>
 
