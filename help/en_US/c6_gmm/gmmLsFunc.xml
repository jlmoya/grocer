   <refnamediv>
       <refname>gmmLsFunc </refname>
               <refpurpose>GMM objective function </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>f = gmmLsFunc(b,gmmopt,Y,X,Z,W)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> b </term> =    parameter vector fed to function</para></listitem>
<listitem><para>*  <term> gmmopt </term> =    gmm options tlist</para></listitem>
<listitem><para>*  <term> Y </term> =    "dependent" variables</para></listitem>
<listitem><para>*  <term> X </term> =    "independent" variables</para></listitem>
<listitem><para>*  <term> Z </term> =    Instruments (can be same as X)</para></listitem>
<listitem><para>*  <term> W </term> =    matrix of weights</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term>  f </term> =    function value evaluated at b</para></listitem>
 
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Evaluates least squares function m(b)'*W*m(b) at b.
<para> </para>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Emmanuel Michaux 2007
        </refsection>
</refentry>
