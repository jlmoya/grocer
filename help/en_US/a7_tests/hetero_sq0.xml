   <refnamediv>
       <refname>hetero_sq0 </refname>
               <refpurpose>Xi² heteroskedasticity test </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[f,f_pvalue,nvar2]=hetero_sq0(r,np)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> r </term> =    results tlist from a first stage estimation</para></listitem>
<listitem><para>*  <term> np </term> =    unused argument put for compatibility with other testing functions</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> f </term> =    value of the Xi² hetero F test</para></listitem>
<listitem><para>*  <term> f_pvalue </term> =    its p-value</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
 Computes the value of the Xi² hetero test. Results are stored as numbers and are not displayed on screen.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
load(GROCERDIR+'/data/bdhenderic.dat');
bounds('1964q3','1989q2');
rols=ols('delts(lm1-lp)','delts(lp)','delts(lagts(1,lm1-lp-ly))','rnet', 'lagts(1,lm1-lp-ly)', 'const');
//performs ols for Hendry and Ericsson (1991) equation 6
[f,f_pvalue,nvar2]=hetero_sq0(rols)
 
// Useful mainly for programming purpose (since hetero_sq does much more).
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
