   <refnamediv>
       <refname>chowtest0  </refname>
               <refpurpose>Chow usual test </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[fstat,f_pvalue,dfnum,dfden]=chowtest0(resulols,n1,np)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> resulols </term> =   a results tlist from a first stage estimation</para></listitem>
<listitem><para>*  <term> n1 </term> =   # of observations of the first sub-period</para></listitem>
<listitem><para>*  <term> np </term>= unused argument put for compatibility with other testing functions</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> fstat </term> =   value of the test statistic</para></listitem>
<listitem><para>*  <term> f_pvalue </term> =   its p-value</para></listitem>
<listitem><para>*  <term> dfnum </term> =   # dof of the numerator</para></listitem>
<listitem><para>*  <term> dfden </term> =   # dof of the denominator</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
 Computes Chow usual test with a break at observation n1. Results are saved as numbers and not displayed on screen.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
load(GROCERDIR+'/data/bdhenderic.dat');
bounds('1964q3','1989q2');
rols=ols('delts(lm1-lp)','delts(lp)','delts(lagts(1,lm1-lp-ly))','rnet', 'lagts(1,lm1-lp-ly)', 'const');
//performs ols for Hendry and Ericsson (1991) equation 6
 
[fstat,f_pvalue,dfnum,dfden]=chowtest0(rols,50)
//Useful mainly for programming purpose (since chowtest does much more).
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
