   <refnamediv>
       <refname>recresid  </refname>
               <refpurpose>recursive residuals </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[rresid]=recresid(y,x)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> y </term> =    dependent variable vector (n x 1)</para></listitem>
<listitem><para>*  <term> x </term> =    explanatory variables matrix (n x k)</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
<listitem><para>*  <term>  rresid </term> =    recursive residuals (first k-obs equal zero) </para></listitem>
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
 Computes recursive residuals.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
x=grand(40,3,'nor',0,1);
y=x*ones(3,1)+grand(40,1,'nor',0,1);
vv = recresid(y,x)
 
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
