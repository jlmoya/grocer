   <refnamediv>
       <refname>cusumq_tab </refname>
               <refpurpose>cusum squared confidence band </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[s] = cusumsq_tab(nobs)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> nobs </term> =    # of observations</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> s </term> =    (3 x 1) vector of (1%, 5%,10%) confidence bounds</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
 Gives the 1%, 5% and 10% stat level of the cusum-squared statistics.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
s=cusumsq_tab(100)
//  Gives the 1%, 5% and 10% stat level of the cusum-squared statistics for 100 observations
 
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
