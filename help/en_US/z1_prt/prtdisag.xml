   <refnamediv>
       <refname>prtdisag </refname>
               <refpurpose>prints the results of a time series disaggregation </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>prtdisag(res,out)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> res </term> =    a results tlist from a disaggregation function</para></listitem>
<listitem><para>*  <term> out </term> =    the file where the results are printed (optional; default: %io(2), i.e the screen)</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing, just print the results</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Prints the results of a time series disaggregation .
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
load(GROCERDIR+'\data\xesp.dat') ;
[y,res] = chowlin('Y','x','ta=-1','typemin=wls','noprint');
prtdisag(res,%io(2))
               ]]></programlisting>
        </refsection>
 
