   <refnamediv>
       <refname>prtvarma </refname>
               <refpurpose>plots partial autocorrelation fonction </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>prtvarma(res)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> res</term>  =    a tlist result from function varma </para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing (printed on a graphic window)</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Prints results of a varma estimation.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
load(GROCERDIR+'/data/varma_d.dat');
 
seriesd = log(seriesd)/log(10);
 
y = transdif(seriesd,1,1,1,12);
 
result=varma('y',0.8,[],[],0.6,0.1,12,'noprint')
 
prtvarma(result)
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
