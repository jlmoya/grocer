   <refnamediv>
       <refname>prtcdtest</refname>
               <refpurpose>Display of the Panel cross-sectional dependence test </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>﻿ []=prtcdtest(res,out)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> res </term> =    the results typed list of a testing regression</para></listitem>
<listitem><para>*  <term> out </term> =    the symobolic name of the file where the results are printed (default: %io(2))</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing: all results are printed on the specified file</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Print the results of cross-sectional dependence tests.
        </refsection>
 
