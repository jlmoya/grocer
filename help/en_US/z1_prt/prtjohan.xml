   <refnamediv>
       <refname>prtjohan </refname>
               <refpurpose>prints Johansen cointegration results </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>prtjohan(res,out)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> res </term> =    a tlist provided by function johansen</para></listitem>
<listitem><para>*  <term> out </term> =    the file where the results are printed (optional; default: %io(2), i.e the screen)</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing, just print the results</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Prints the results of a Johansen cointegration test on the file out.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
bounds()
 
load(GROCERDIR+'\data\juselius.dat')
dum75q4=dummy(['1973q1';'2003q1'],'1975q4')-0.5*dummy(['1973q1';'2003q1'],['1976q1';'1976q2']);
dum76q4=dummy(['1973q1';'2003q1'],'1976q4');
dum83q2=dummy(['1973q1';'2003q1'],'1983q2');
dum83q1=dummy(['1973q1';'2003q1'],'1983q1');
rj1=johansen(1,'dnk_Lm3rC','dnk_Lyr','dnk_DLpy','dnk_Rm','dnk_Rb',...
'exo_lt=trend^1;post(1983q1)','exo_st=const;dum75q4;dum76q4;dum83q1','noprint')
 
prtjohan(rj1,%io(2))
 
 
               ]]></programlisting>
        </refsection>
 
