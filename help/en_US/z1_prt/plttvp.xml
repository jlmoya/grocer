   <refnamediv>
       <refname>plttvp </refname>
               <refpurpose>plots tvp results </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>plttvp(res)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> res </term> =    the results typed list of a tvp regression </para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing (printed on a graphic window)</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Plots the coefficients of a time-varying regression.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
load(GROCERDIR+'/data/cousa.dat')
 
bounds();
rols=ols('con','inc','cte')
b=rols('beta')
sigu=sqrt(rols('sigu'))
disp('like ols:')
disp(rols('llike'))
timer();
res=tvp('con','inc','cte','R=sigu','Q=0.1*eye(2,2)','priorb0=b','priorv0=100000*eye(2,2)','tvpmeth=1','optmeth=optim','noprint')
plttvp(res)
               ]]></programlisting>
        </refsection>
 
