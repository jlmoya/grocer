   <refnamediv>
       <refname>ndigits</refname>
               <refpurpose>Rounds all elements of a matrix to the desired number of decimals </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>matr = ndigits(mat,digits)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> mat </term> =    a (n x k) matrix</para></listitem>
<listitem><para>*  <term> digits</term>  =    number of digits to display in each columns</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> matr </term> =    a (n x k) string matrix rounded to the desired number of decimals</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Rounds a matrix to the desired number of decimals and converts it into string
 
        </refsection>
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
ndigits(grand(5,3,'nor',0,1),2)
               ]]></programlisting>
        </refsection>
 
 
