   <refnamediv>
       <refname>pltuniv </refname>
               <refpurpose>plots univariate results </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>pltuniv(res,options)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> res </term> =  the results typed list of function dfbeta</para></listitem>
<listitem><para>*  <term> options </term> =  'res', 'fitted', or 'all' according to the results that the user wants to graph (default: all)</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing (printed on a graphic window)</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Plots the results of least-squares regression.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
load(GROCERDIR+'/data/bdhenderic.dat');
bounds('1964q3','1989q2');
rhe=ols('delts(lm1-lp)','delts(lp)','delts(lagts(1,lm1-lp-ly))','rnet', 'lagts(1,lm1-lp-ly)', 'const','noprint');
 
pltuniv(rhe)
pltuniv(rhe,'all')
// now only the graph of residuals
 
// These 2 examples do the same thing: graph residuals on a graph and observed and fitted values on another graph.
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
