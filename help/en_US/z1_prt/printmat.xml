   <refnamediv>
       <refname>printmat </refname>
               <refpurpose>prints a matrix </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>printmat(mat,out)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> mat </term> =    the matrix to print</para></listitem>
<listitem><para>*  <term> out </term> =    the symbolic name of the file where the results are printed</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing: all results are printed on the specified file</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Prints a matrix with aligned columns.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
x= grand(4,3,'nor',0,1)
labels=['date\variable'  'junk' 'variable' 'unknown']
mat2=[string(1:4)' string(x)]
printmat([labels ; mat2],%io(2))
 
               ]]></programlisting>
        </refsection>
 
