   <refnamediv>
       <refname>prttvp </refname>
               <refpurpose>prints tvp estimation results </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>prttvp(res,out)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> res </term> =    a tlist provided by a tvp function</para></listitem>
<listitem><para>*  <term> out </term> =    the file where the results are printed (optional; default: %io(2), i.e the screen)</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing, just print the results</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Prints time varying parameters regression results.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
load(GROCERDIR+'/data/cousa.dat')
 
bounds();
rols=ols('con','inc','cte')
b=rols('beta')
sigu=sqrt(rols('sigu'))
r1=tvp('con','inc','const','R=sigu','Q=0.1*eye(2,2)','priorb0=b','priorv0=100000*eye(2,2)','tvpmeth=1','optmeth=optim','noprint')
 
 
prttvp(r1,%io(2))
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
