   <refnamediv>
       <refname>pltirf2 </refname>
               <refpurpose>plots impulse functions </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>pltirf2(res)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> res </term> =    the results typed list of function irf</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing (printed on a graphic window)</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Plots the results of the impulse functions from a var regression on a single graph window.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
load(GROCERDIR+'/data/lutk1.dat')
bounds('1960q4','1978q4')
results=VAR(2,'endo=delts(log(rfa_inv));delts(log(rfa_inc));delts(log(rfa_cons))')
// a calculation with orthogonized residuals and asymptotic confidence band
[resirf]=irf(results,10,'mres=chol1','meth=asym')
// now plot impulse response functions
pltirf2(resirf)
 
               ]]></programlisting>
        </refsection>
 
