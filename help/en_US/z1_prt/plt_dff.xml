   <refnamediv>
       <refname>plt_dff </refname>
               <refpurpose>plots dffits, studentized residuals ... </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>plt_dff(res)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> res </term> =    the results typed list of function dfbeta</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing (printed on a graphic window)</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Plots the dffits, studentized residuals and hat-matrix diagonal. Opens a new graphic window.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
exo = grand(100,6,'nor',0,1);
exo(:,1) = ones(100,1);
exo(:,3) = exo(:,2) + grand(100,1,'nor',0,1)*0.05;
 
bet = ones(6,1);
 
endo = exo*bet + grand(100,1,'nor',0,1);
 
// now add a few outliers
endo(50,1) = 10.0;
endo(70,1) = -10.0;
 
// run dfbeta without printing and plotting the results
res = dfbeta('endo','exo','noprint');
 
// now plot the result
plt_dff(res)
               ]]></programlisting>
        </refsection>
 
