   <refnamediv>
       <refname>font_title </refname>
               <refpurpose>changes the font of the title </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>font_title(font,wind)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> f</term>  =    size of the font</para></listitem>
<listitem><para>*  <term> wind </term> =    number of an open window</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing: the current graphic window is modified</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Changes the font of the title.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
font_title(4,0)
// Set to 4 the font of the title of the graph in window number 0.
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
