   <refnamediv>
       <refname>prtfac_acp </refname>
               <refpurpose>prints static factor estimation results </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>prtfac_pca(res,out)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term> res </term> =    a tlist provided by a fac_acp function</para></listitem>
<listitem><para>*  <term> out </term> =    the file where the results are printed (optional; default: %io(2), i.e the screen)</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>* nothing, just print the results</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Prints static factor analysis results.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
load(GROCERDIR+'/data/BusinessSurvey.dat');
 
 
// performs DFA and keep the first factor
res = fac_pca('pp','fp','gpp','gob','fob','in','pnum=6','snum=1');
 
prtfac_acp(res,%io(2))
 
//Prints on screen the tlist result coming from a static factor analysis.
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
