   <refnamediv>
       <refname>rebuild_eq</refname>
               <refpurpose>build an equation from an analytic tlist </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>equation=rebuild_eq(reseq)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
 
<listitem><para>*  <term>reseq</term> =    an 'equation' tlist</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
 
<listitem><para>*  <term>equation</term>  =    a string, the text of an equation</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
from an 'equation' tlist, recover the corresponding equation.
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
eq='a*x^2+b*sin(0.5*x)';
an_eq=analyse_eq(eq);
deriv=deriv_eq1(an_eq,'x');
eqd=rebuild_eq(deriv)
 // note that the function can be somehow simplified:
eqds=rebuild_eq(simplify_eq(deriv))
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2012
        </refsection>
</refentry>
