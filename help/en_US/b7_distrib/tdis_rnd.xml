   <refnamediv>
       <refname>tdis_rnd </refname>
               <refpurpose>Student random draws </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[t]=tdis_rnd(n,df)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> n </term> =    size of vector</para></listitem>
<listitem><para>*  <term> df </term> =    a scalar dof parameter</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> t </term> =    a vector of random draws from the t(n) distribution</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Returns random draws from the t(n) distribution.
 NOTE: mean=0, std=1
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
x=tdis_rnd(100,25)
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
