   <refnamediv>
       <refname>beta_rnd  </refname>
               <refpurpose>beta random draws </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[rnd]=beta_rnd(n,a,b)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> n </term> =    size of the vector of draws</para></listitem>
<listitem><para>*  <term> a </term> =    beta distribution parameter, a  =    scalar</para></listitem>
<listitem><para>*  <term> b </term> =    beta distribution parameter b  =    scalar</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> rnd </term> =    n-vector of random draws from the beta(a,b) distribution</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Random draws from the beta(a,b) distribution.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
x=beta_rnd(100,10,5)
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
