   <refnamediv>
       <refname>unif_rnd </refname>
               <refpurpose>Uniform random draws </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[rnd]=unif_rnd(n,a,b)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> a </term> =    scalar left limit</para></listitem>
<listitem><para>*  <term> b </term> =    scalar right limit</para></listitem>
<listitem><para>*  <term> n </term> =    number of draws (default  =    1)</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> rnd </term> =    (n x 1) draws from the normal distribution</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Returns a uniform random number between a,b.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
x=unif_rnd(100,2,8)
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
