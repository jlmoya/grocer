   <refnamediv>
       <refname>pois_rnd </refname>
               <refpurpose>Poisson random draws </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[y]=pois_rnd(n,lambda)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> lambda </term> =    mean used for the draws</para></listitem>
<listitem><para>*  <term> n </term> =    # of draws</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> y </term> =    a vector of draws</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Generates random draws from the Poisson distribution.
<para>  NOTES: </para>
  Uses naive inversion method.
 mean = lambda, variance = lambda
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
x=pois_rnd(10,2)
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
