   <refnamediv>
       <refname>norm_pdf </refname>
               <refpurpose>normal distribution </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[pdf]=norm_pdf(x,m,v)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> x </term> =    variable vector (rxc)</para></listitem>
<listitem><para>*  <term> m </term> =    mean vector (default  =   0)</para></listitem>
<listitem><para>*  <term> v </term> =    variance vector (default  =   1)</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> pdf </term> =    (rxc) vector containing pdf for each value of x</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Computes the normal probability density function for each component of x with mean m, variance v.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
x=norm_pdf([1 2; 3 4])
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
