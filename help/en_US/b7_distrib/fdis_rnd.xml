   <refnamediv>
       <refname>fdis_rnd </refname>
               <refpurpose>Fisher random draws </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[x]=fdis_rnd(n,a,b)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> n </term> =    size of vector</para></listitem>
<listitem><para>*  <term> a </term> =    scalar dof parameter</para></listitem>
<listitem><para>*  <term> b </term> =    scalar dof parameter</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> x </term> =    a vector of random draws from the F(a,b) distribution</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Returns random draws from the F(a,b) distribution.
  NOTE: mean should equal (b/a)*((a/2)/(b/2-1)).
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
x=fdis_rnd(100,2,18)
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
