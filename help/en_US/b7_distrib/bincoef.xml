   <refnamediv>
       <refname>bincoef </refname>
               <refpurpose>binomial coefficients </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[k]=bincoef(n,N)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> n </term> =    (mxp) matrix</para></listitem>
<listitem><para>*  <term> N </term> =    (nxp) matrix (same size than n) or scalar</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> k </term> =    (mxp) matrix of binomial coefficents with</para></listitem>
<listitem><para>&#160;  - k(i,j)=binomial(n(i,j),N(i,j)) or</para></listitem>
<listitem><para>&#160;  - k(i,j)=binomial(n(i,j),N) if N is a scalar</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Generates binomial coefficients.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
k=bincoef(5,15)
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
