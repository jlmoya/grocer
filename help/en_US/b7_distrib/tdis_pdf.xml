   <refnamediv>
       <refname>tdis_pdf </refname>
               <refpurpose>Student probability distribution </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[pdf]=tdis_pdf(x,n)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> x </term> =    a matrix, vector or scalar</para></listitem>
<listitem><para>*  <term> n </term> =    a matrix or scalar parameter with dof</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> pdf </term> =    a matrix of pdf at each element of x of the t(n) distribution</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Returns the probability distribution function at x of the t(n) distribution.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
x=tdis_pdf(2+[-5:5]/10,56)
x=tdis_pdf(2*ones(5,1),[10 ; 100 ; 1000 ; 10000 ; 100000])
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
