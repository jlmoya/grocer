   <refnamediv>
       <refname>quantile </refname>
               <refpurpose>calculate the quantiles of variables </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[Y]=quantile(X,p)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> X </term> =    a (n x r) matrix</para></listitem>
<listitem><para>*  <term> p </term> =    p is a scalar or a (np x 1) vector of cumulative probability values</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> Y </term> =    a (np x r) matrix of quantiles</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Calculate the quantiles of variables X.
 
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
 
x = grand(15,4,'nor',0,1);
y=quantile(x,[.025 .25 .50 .75 .975])
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2011
        </refsection>
</refentry>
