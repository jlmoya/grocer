   </info>
   <refnamediv>
       <refname>spencer</refname>
               <refpurpose>filters a series with a Spencer filter </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>xsp = spencer(x)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> x </term> =    a (n x 1) real vector </para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> xsp</term>  =   a (n x 1) real vector</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Filter a series using a 15-term two-sided Spencer filter.


        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
load(GROCERDIR+'/data/bdhenderic.dat');
lm1_sp=spencer(series(lm1))
               ]]></programlisting>
        </refsection>
 
