  <info>
     <pubdate>$LastChangedDate:2-Nov-2009$</pubdate>
   </info>
   <refnamediv>
       <refname>autocum</refname>
               <refpurpose>AR(1) cumulation </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[serieout]=autocum(seriein,rho)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> seriein </term> =    a (n x 1) or (1 x n) constant vector or a timeseries</para></listitem>
<listitem><para>*  <term> rho </term> =    a constant</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> serieout </term> =    the vector (n x 1) or ts y such as:</para></listitem>
<listitem><para>*  <term> y(t) </term> =    rho*y(t-1) + x(t)</para></listitem>
<listitem><para>*  <term> y(t0) </term> =    x(t0) for the first observation t0</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Provides the vector (n x 1) or ts y such as:
* y(t) = rho*y(t-1) + x(t)
* y(t0) = x(t0) for the first observation t0


        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[x=[1.2 ; 0.9 ; 1.3; 0.5;1.25; 1.32];
y=autocum(x,0.9)

               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
