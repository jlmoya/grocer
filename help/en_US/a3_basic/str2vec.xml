   </info>
   <refnamediv>
       <refname>str2vec</refname>
               <refpurpose>string to vector of strings </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[s]=str2vec(name,arg1,...,argn)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> name </term> =    a string</para></listitem>
<listitem><para>*  <term> argi </term> =    a string indicating a separator</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> s </term> =    a (n x 1) vector of names </para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Given a string 'xxx=[yy1 sep ...sep yyn]', define the vector ['yy1';...;'yyn'] 

        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
str2vec('a=b,c,d',',') // returns
//!b  !
//!c  !
//!d  !
 
grocer_coef=str2vec(grocer_coef)// Example taken from nls: str2vec is used to transform into a vector the list of coefficient names given by the user.

               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
