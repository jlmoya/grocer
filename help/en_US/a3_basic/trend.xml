   </info>
   <refnamediv>
       <refname>trend</refname>
               <refpurpose>exponentiated time trend </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[xmat]=trend(p,nobs)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> p </term> =    exponent of the time-trend</para></listitem>
<listitem><para>*  <term> nobs </term> =    size of the matrix</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
<listitem><para>*  <term> xmat </term> =     (nobsx1) vector containing trend </para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Produces a vector equal to a time-trend with exponentiation p. 

        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
ext=trend(2,10)// returns
//!   1.   !//!   4.   !//!   9.   !//!   16.  !//!   25.  !//!   36.  !//!   49.  !//!   64.  !//!   81.  !//!   100. !
               ]]></programlisting>
        </refsection>
 
