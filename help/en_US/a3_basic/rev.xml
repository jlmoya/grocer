   <refnamediv>
       <refname>rev</refname>
               <refpurpose>mimics gauss function rev </refpurpose>
   </refnamediv>
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[B]=rev(A)</synopsis>
        </refsynopsisdiv>
         <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>           <term>Input</term>
<listitem><para>*  <term> A </term> =   a (nxp) matrix</para></listitem>
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>          <varlistentry>
          <term>Output</term>
<listitem><para>*  <term> B </term> =   a (nxp) matrix</para></listitem>
          </varlistentry>
          </variablelist>
        </refsection>
        <refsection>
               <title>DESCRIPTION</title>
Function that mimics gauss function rev: reverses the order of the rows of a matrix 
        </refsection>
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
A = [1 2 ; 3  4 ; 5 6];B=rev(A)//returns
////B  =//!   5.    6. !//!   3.    4. !//!   1.    2. !     
               ]]></programlisting>
        </refsection>
        <refsection>
               <title>AUTHOR</title>
