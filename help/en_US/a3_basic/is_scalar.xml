   <refnamediv>
       <refname>is_scalar</refname>
               <refpurpose>check if a matrix is a scalar </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[ret]=is_scalar(x)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
<listitem><para>*  <term> x </term> =    a (nxm) matrix </para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> ret0 </term> =    1 if x is scalar, 0 in other cases</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Checks if a matrix is a scalar 

        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
is_scalar(5)//returns 1
 
is_scalar(ones((4,1))//returns 0. 

               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
