   <refnamediv>
       <refname>invvech</refname>
               <refpurpose>inverse of vech </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[xi]=invvech(x,nr)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> x </term> =    a (nrx1) vector</para></listitem>
<listitem><para>*  <term> nr </term> =    # of rows of the original matrix</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> xi </term> =    the original -vectorized by vech- matrix </para></listitem>
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Retrieves from a matrix vectorized by vech the original matrix 

        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
a=grand(5,2,'nor',0,1);b=vech(a'*a);c=invvech(b,2)// c is equal to a'*a 

               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
