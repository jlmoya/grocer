   <refnamediv>
       <refname>vech</refname>
               <refpurpose>stacks a symmetric matrix </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[v]=vech(x)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
<listitem><para>*  <term> x </term> =    an input matrix </para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
<listitem><para>*  <term> v </term> =    output vector containing stacked columns of x </para></listitem>
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Creates a column vector by stacking columns of x on and below the diagonal  

        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
vech([1 0.5; 0.5 2]')  //returns:
//!   1.  !//!    .5 !//!   2.  !

               ]]></programlisting>
        </refsection>
 
