   <refnamediv>
       <refname>getconfig</refname>
               <refpurpose>Get the name of the O/S </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>OSNAME = getconfig()</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>* nothing</para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> OSNAME </term> =    the name of the O/S</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
gets the name of the OS.
        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
OS=getconfig()
 
               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
&#201;ric Dubois 2014
