   <refnamediv>
       <refname>miss</refname>
               <refpurpose>converts a specified value to NA </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>v=miss(mat,val)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> mat </term> =    a (nxp) matrix</para></listitem>
<listitem><para>*  <term> val </term> =    a scalar</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> mat </term> =    a (nxp) matrix</para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Function that mimics gauss function miss: converts to NA prespecified values in a matrix 

        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
x1=ones(7,1);x2=[1:7]';v = miss([x1 x2],7)// returns:
// v  =//!   1.    1. !//!   1.    2. !//!   1.    3. !//!   1.    4. !//!   1.    5. !//!   1.    6. !//!   1.  %Nan !  
               ]]></programlisting>
        </refsection>
 
