   <refnamediv>
       <refname>vec2col</refname>
               <refpurpose>vector into column vector </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[x]=vec2col(x)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
 
<listitem><para>*  <term> x </term> =    (1 x n) or (n x 1) vector</para></listitem>
 
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
 
<listitem><para>*  <term> x </term> =    (n x 1) vector </para></listitem>
 
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Transforms a row or col vector into a col vector. 

        </refsection>
 
        <refsection>
               <title>EXAMPLE</title>
              <programlisting role="example"><![CDATA[
vec2col([3:7])vec2col([3:7]')// both command return:
//!   3. !
//!   4. !
//!   5. !
//!   6. !
//!   7. !
 
grocer_init=vec2col(grocer_init)// Example taken from nls: transforms into a column vector the vector of starting values for the optimisation algorithm. This allows the user to give either a column or a row vector and therefore facilitates her life.

               ]]></programlisting>
        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
</refentry>
