   <refnamediv>
       <refname>var2cor</refname>
               <refpurpose>covariance to correlation </refpurpose>
   </refnamediv>
 
        <refsynopsisdiv>
               <title>CALLING SEQUENCE</title>
               <synopsis>[c]=var2cor(s)</synopsis>
        </refsynopsisdiv>
 
        <refsection>
           <title>PARAMETERS</title>
           <variablelist>
           <varlistentry>
 
           <term>Input</term>
<listitem><para>*  <term> s </term> =    (n x n) covariance matrix </para></listitem>
 
 
<listitem><para>&#160;</para></listitem>
 
           </varlistentry>
 
          <varlistentry>
 
          <term>Output</term>
<listitem><para>*  <term> c </term> =    (n x n) correlation matrix </para></listitem>
 
          </varlistentry>
          </variablelist>
        </refsection>
 
        <refsection>
               <title>DESCRIPTION</title>
Transforms a covariance matrix into a correlation matrix. 

        </refsection>
 
        <refsection>
               <title>AUTHOR</title>
Eric Dubois 2002
        </refsection>
